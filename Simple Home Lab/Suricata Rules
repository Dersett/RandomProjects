# REVERSE SHELL DETECTION
# Detects unencrypted command shell traffic. 
#"uid=0(root)" is the output of the 'id' command, common in initial recon.

	  alert tcp $IOT_NET any -> $EXTERNAL_NET any (msg:"ATTACK-RESPONSE Possible Linux Reverse Shell (id command output)"; flow:established; content:"uid=0(root)"; fast_pattern; classtype:successful-admin; sid:1000062; rev:1;)

#Detects spawning of a shell process over the wire

	  alert tcp $IOT_NET any -> $EXTERNAL_NET any (msg:"ATTACK-RESPONSE Possible Reverse Shell Spawn (/bin/sh)"; flow:established; content:"/bin/sh"; fast_pattern; classtype:web-application-attack; sid:1000063; rev:1;)
	
	
#Alert on HTTP POST Requests (Data Upload/Exfiltration)
# Mechanism: Checks the HTTP Method field for "POST".
# Logic: IoT devices rarely send data OUT (POST) unless authorized. 
# Unexpected POSTs indicate malware C2 check-ins or data theft.
	
	  alert http any any -> any any (msg:"HTTP POST Request Detected"; flow:established,to_server; http.method; content:"POST"; classtype:policy-violation; sid:1000516; rev:1;)
